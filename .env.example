# Copy this file to .env for local development (never commit .env)

# Telegram bot token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Chat ID of the main Telegram group/channel to send notifications to.
# To find it: type /id in the group with the bot. Leave empty to use individual subscriptions only.
GROUP_CHAT_ID=

# Supabase credentials (project authfm-staging)
SUPABASE_URL=https://xniuwcvehkyfjktfljfd.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
