# Copy this file to .env for local development (never commit .env)

# Telegram bot token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Chat ID of the main Telegram group/channel to send notifications to.
# To find it: add @userinfobot to the group, it will reply with the chat ID.
# Leave empty to only notify individual subscribers.
GROUP_CHAT_ID=

# Path to the persistent JSON storage file.
# On Railway, set this to /data/storage.json (after mounting a Volume on /data).
# For local development, the default "storage.json" works fine.
STORAGE_PATH=storage.json
